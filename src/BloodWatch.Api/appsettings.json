{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "BloodWatch": ""
  },
  "BloodWatch": {
    "Build": {
      "Version": "",
      "Commit": "",
      "Date": ""
    },
    "Api": {
      "Caching": {
        "LatestTtlSeconds": 60
      },
      "RateLimiting": {
        "PermitLimitPerMinute": 60,
        "QueueLimit": 0
      }
    },
    "Copilot": {
      "Enabled": false,
      "DefaultSource": "pt-dador-ipst",
      "AdminApiKey": "",
      "DefaultAnalyticsWeeks": 8,
      "DefaultAnalyticsLimit": 20,
      "RateLimiting": {
        "PermitLimitPerMinute": 20,
        "QueueLimit": 0
      },
      "Guardrails": {
        "MaxQuestionLength": 1000
      },
      "Control": {
        "Enabled": false,
        "OperationTimeoutSeconds": 60,
        "HealthProbeTimeoutSeconds": 30,
        "OllamaContainerName": "bloodwatch-ollama",
        "OllamaModelInitContainerName": "bloodwatch-ollama-model-init"
      }
    },
    "JwtAuth": {
      "Enabled": true,
      "Issuer": "bloodwatch-api",
      "Audience": "bloodwatch-clients",
      "SigningKey": "",
      "AccessTokenMinutes": 15,
      "AdminEmail": "",
      "AdminPasswordHash": ""
    }
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "llama3.1",
    "TimeoutSeconds": 30,
    "MaxRetries": 2
  },
  "AllowedHosts": "*"
}
