# ---------------------------
# Shared runtime metadata
# ---------------------------
ConnectionStrings__BloodWatch=
BLOODWATCH_CONNECTION_STRING=
BloodWatch__Build__Version=
BloodWatch__Build__Commit=
BloodWatch__Build__Date=

# ---------------------------
# JWT auth (required in production)
# ---------------------------
BloodWatch__JwtAuth__Enabled=true
BloodWatch__JwtAuth__Issuer=bloodwatch-api
BloodWatch__JwtAuth__Audience=bloodwatch-clients
BloodWatch__JwtAuth__SigningKey=
BloodWatch__JwtAuth__AccessTokenMinutes=15
BloodWatch__JwtAuth__AdminEmail=
BloodWatch__JwtAuth__AdminPasswordHash=

# ---------------------------
# Copilot / Ollama
# ---------------------------
BloodWatch__Copilot__Enabled=false
BloodWatch__Copilot__AdminApiKey=
BloodWatch__Copilot__Control__Enabled=true
BloodWatch__Copilot__Control__OperationTimeoutSeconds=60
BloodWatch__Copilot__Control__HealthProbeTimeoutSeconds=30
OLLAMA__BASE_URL=http://ollama:11434
OLLAMA__MODEL=qwen2.5:0.5b
OLLAMA__TIMEOUT_SECONDS=30
OLLAMA__MAX_RETRIES=2
OLLAMA__MEM_LIMIT=2g
HOST_DOCKER_GID=998

# ---------------------------
# Notification/runtime secrets
# ---------------------------
BLOODWATCH__TELEGRAM_BOT_TOKEN=
BLOODWATCH__TELEGRAM_TIMEOUT_SECONDS=10
BLOODWATCH__DISCORD_WEBHOOK_TIMEOUT_SECONDS=10
BloodWatch__Worker__FetchPortugalReserves__IntervalMinutes=10

# ---------------------------
# Production compose (deploy/docker-compose.prod.yml)
# ---------------------------
BLOODWATCH_IMAGE_TAG=
BLOODWATCH_API_IMAGE=ghcr.io/igorbmaciel/bloodwatch-api
BLOODWATCH_WORKER_IMAGE=ghcr.io/igorbmaciel/bloodwatch-worker

POSTGRES_DB=bloodwatch
POSTGRES_USER=bloodwatch
POSTGRES_PASSWORD=

CADDY_EMAIL=
